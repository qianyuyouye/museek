# 数据库（必填）
DATABASE_URL="mysql://root:密码@localhost:3306/museek"

# JWT 认证（必填，生产环境必须修改）
JWT_SECRET="change-me-in-production"

# 身份证等敏感字段加密密钥（必填，32 字节十六进制，生产环境必须配置）
# 生成命令：openssl rand -hex 32
ENCRYPTION_KEY=""

# Docker 部署时的 MySQL 密码
MYSQL_ROOT_PASSWORD="museek2026"

# 阿里云短信（可选，不配则短信验证码固定为 123456）
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# 阿里云 OSS 文件上传（可选，不配则上传到本地 public/uploads/）
OSS_BUCKET=""
OSS_REGION=""
OSS_DOMAIN=""

# AI 预分析（可选，不配则返回默认值）
AI_API_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"

# Theme 5: 上传链路密钥与存储根目录
# UPLOAD_SECRET 不配则从 JWT_SECRET 派生（sha256(JWT_SECRET + ":upload")）
UPLOAD_SECRET=
# 本地模式下文件落盘根目录，默认 ./storage（Docker 生产建议挂载持久卷）
STORAGE_ROOT=./storage
